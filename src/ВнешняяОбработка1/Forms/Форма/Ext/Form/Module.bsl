&НаКлиенте
Процедура ПрочитатьExcel(Команда)
    Если ПустаяСтрока(Объект.ПутьКФайлу) Тогда
        Сообщить("Укажите путь к файлу Excel!");
        Возврат;
    КонецЕсли;
    
    ТабДок = Новый ТабличныйДокумент;
    Попытка
        ТабДок.Прочитать(Объект.ПутьКФайлу);
    Исключение
        Сообщить("Ошибка чтения файла. Проверьте путь.");
        Возврат;
    КонецПопытки;

    РазобратьТабличныйДокументНаСервере(ТабДок);
КонецПроцедуры

&НаСервере
Процедура РазобратьТабличныйДокументНаСервере(ТабДок)
    Объект.ДанныеФайла.Очистить();
    
    Для ИндексСтроки = 2 По ТабДок.ВысотаТаблицы Цикл
        ИННСтрока = СокрЛП(ТабДок.Область(ИндексСтроки, 1).Текст);
        Если ПустаяСтрока(ИННСтрока) Тогда Продолжить; КонецЕсли;
        
        НоваяСтрока = Объект.ДанныеФайла.Добавить();
        НоваяСтрока.Пометка = Истина;
        НоваяСтрока.ИНН = ИННСтрока;
        Попытка
            НоваяСтрока.Сумма = Число(СтрЗаменить(ТабДок.Область(ИндексСтроки, 2).Текст, Символы.НПП, ""));
        Исключение
            НоваяСтрока.Сумма = 0;
        КонецПопытки;
        НоваяСтрока.Назначение = ТабДок.Область(ИндексСтроки, 3).Текст;
        
        НайденныйКонтрагент = Справочники.Контрагенты.НайтиПоРеквизиту("ИНН", НоваяСтрока.ИНН);
        Если ЗначениеЗаполнено(НайденныйКонтрагент) Тогда
            НоваяСтрока.Контрагент = НайденныйКонтрагент;
            НоваяСтрока.Статус = "Готов к созданию";
        Иначе
            НоваяСтрока.Статус = "Контрагент не найден!";
        КонецЕсли;
    КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура СоздатьДокументы(Команда)
    Если Не ЗначениеЗаполнено(Объект.Организация) Тогда
        Сообщить("Заполните реквизит Организация!");
        Возврат;
    КонецЕсли;
    СоздатьДокументыНаСервере();
    Сообщить("Готово!");
КонецПроцедуры

&НаСервере
Процедура СоздатьДокументыНаСервере()
    Для Каждого СтрокаТЗ Из Объект.ДанныеФайла Цикл
        Если Не СтрокаТЗ.Пометка Или Не ЗначениеЗаполнено(СтрокаТЗ.Контрагент) Тогда Продолжить; КонецЕсли;
        
        Док = Документы.ПлатежноеПоручение.СоздатьДокумент();
        Док.Дата = ТекущаяДата();
        Док.Организация = Объект.Организация;
        Док.ВидОперации = Перечисления.ВидыОперацийСписаниеДенежныхСредств.ОплатаПоставщику;
        Док.Контрагент = СтрокаТЗ.Контрагент;
        Док.СуммаДокумента = СтрокаТЗ.Сумма;
        Док.НазначениеПлатежа = СтрокаТЗ.Назначение;
        Док.СтавкаНДС = Справочники.СтавкиНДС.БезНДС; 
        
        Попытка
            Док.Записать(РежимЗаписиДокумента.Запись);
            СтрокаТЗ.Статус = "Создан!";
            СтрокаТЗ.Пометка = Ложь;
        Исключение
            СтрокаТЗ.Статус = "Ошибка!";
        КонецПопытки;
    КонецЦикла;
КонецПроцедуры